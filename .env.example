# AWS Service Control for Learner Labs
# Set to 'true' only if AWS services are properly configured
# Default to 'false' to use local fallbacks

# Disable AWS Comprehend (use local NLP instead)
ENABLE_COMPREHEND=false

# Disable AWS Textract (use mock OCR instead)  
ENABLE_TEXTRACT=false

# Disable AWS Transcribe (use browser transcription instead)
ENABLE_TRANSCRIBE=false

# Disable AWS Polly (use browser TTS instead)
ENABLE_POLLY=false

# Disable AWS Translate (use passthrough instead)
ENABLE_TRANSLATE=false

# Database
ENABLE_DYNAMO=false

# JWT Settings
JWT_SECRET=project77_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Cognito Settings (usually false in development)
ENABLE_COGNITO=false
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxx

# AWS Region (if using AWS services)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_SESSION_TOKEN=your_session_token

# Server
PORT=5000
NODE_ENV=development
