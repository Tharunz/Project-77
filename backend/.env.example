# ============================================
# Project-77 Backend — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Authentication
# → AWS swap: Replace with Amazon Cognito User Pool config
JWT_SECRET=project77_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Email Notifications (Gmail SMTP)
# → AWS swap: Replace with AWS SES credentials
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Project-77 Gov Portal <noreply@project77.gov.in>"

# File Storage
# → AWS swap: Replace with S3 bucket name + region
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Database
# → AWS swap: Replace with DynamoDB or RDS config
DB_PATH=./db/local.json

